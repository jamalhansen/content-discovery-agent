# Content Discovery Agent configuration
# Copy this file to .content-discovery.toml and edit to your liking.
# .content-discovery.toml is gitignored — safe to put personal URLs and interests here.

[feeds]
urls = [
    "https://simonwillison.net/atom/everything/",
    "https://realpython.com/atom.xml",
    "https://news.ycombinator.com/rss",
    "https://pycoders.com/feed/index.xml",
    "https://duckdb.org/feed.xml",
    "https://ollama.com/blog/rss",
]

[interests]
# Describe what you care about in plain prose. The LLM uses this directly.
# Adding a topic is as simple as mentioning it here.
profile = """
I'm interested in Python, SQL, data engineering, local AI, and LLMs.
I follow technical writing craft and practical developer tooling.
"""

# Optional: topics, formats, and sources to score low.
# Included in every prompt as "Not interested in: <exclusions>".
# Use this to suppress content that keeps scoring high but you always dismiss.
# exclusions = """
# JavaScript/React/CSS tutorials, YouTube videos, job listings,
# non-English content, personal lifestyle newsletters,
# security CVE feeds, generic "AI is changing everything" opinion pieces.
# """

[settings]
# Minimum relevance score to include an item (0.0–1.0)
threshold = 0.7

# Default LLM provider: local, anthropic, groq, deepseek
provider = "local"

# Path to your Obsidian vault root (overrides OBSIDIAN_VAULT_PATH env var)
# vault_path = "~/vaults/MyVault/"

# Path to the finds inbox, relative to vault root
inbox_path = "_finds/00-inbox.md"

# Path to the SQLite database (default: ~/.content-discovery.db)
# For multi-machine sync with Syncthing, point this at your shared sync folder.
# The CONTENT_DISCOVERY_STORE env var overrides this if set.
# store = "~/sync/content-discovery/store.db"

[social]
# Keywords used to search Bluesky and Mastodon hashtag timelines.
# Multi-word keywords work in Bluesky search; spaces are stripped for Mastodon hashtags.
# ("local ai" → searches Bluesky for "local ai", Mastodon for #localai)
keywords = ["duckdb", "python", "local ai", "ollama", "sql"]

# Mastodon instances to search. Any public instance works — no auth required.
mastodon_instances = ["mastodon.social", "fosstodon.org"]

# Additional domains to skip when fetching article URLs from social posts.
# Medium and its publication network are blocked by default (no need to list them here).
# Add any other paywalled or bot-blocking sites you want to skip.
# Subdomain matching is automatic — "nytimes.com" also blocks "www.nytimes.com".
blocked_domains = []

# Bluesky authentication (recommended).
# Bluesky's public search endpoint intermittently returns 403 for unauthenticated
# requests. Set BLUESKY_HANDLE and BLUESKY_APP_PASSWORD as environment variables
# (not here — keep credentials out of config files).
#
# Generate an App Password in Bluesky → Settings → Privacy and Security → App Passwords.
# Then add to your shell profile:
#   export BLUESKY_HANDLE=you.bsky.social
#   export BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
